# GEMINI_API_KEY: Required for Gemini AI API calls.
#
# Option A — plain env (copy this file to `.env` and fill in):
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
#
# Option B — encrypted at rest (@chainlink/env-enc, file `.env.enc`):
#   1. In each new terminal session: npx env-enc set-pw
#   2. npx env-enc set   # follow prompts to set GEMINI_API_KEY
#   3. npm run dev       # vite.config decrypts .env.enc before build
# You can commit `.env.enc` if you want; keep the password private.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
